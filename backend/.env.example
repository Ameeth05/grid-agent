# GridAgent Backend Orchestrator Environment Variables
# Copy this file to .env and fill in your values
#
# For Railway deployment, set these in the Railway dashboard:
# https://railway.app/project/[your-project]/settings/variables

# ===========================================
# REQUIRED: Anthropic API Key
# ===========================================
# This is injected into E2B sandboxes for the AI agent
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# ===========================================
# REQUIRED: E2B API Key
# ===========================================
# Get from: https://e2b.dev/dashboard
E2B_API_KEY=e2b_...

# ===========================================
# REQUIRED: Supabase Configuration
# ===========================================
# Get from your Supabase project settings: Settings -> API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT secret for verifying Supabase tokens (HS256)
# Found in Supabase Dashboard -> Settings -> API -> JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ===========================================
# OPTIONAL: Server Configuration
# ===========================================
# Port to run the server on (Railway sets this automatically)
PORT=8000

# Environment: development or production
ENV=production

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log format: json (for production) or text (for local dev)
LOG_FORMAT=json

# Frontend URL for additional CORS origin (Vercel patterns handled automatically)
FRONTEND_URL=https://your-frontend.vercel.app

# ===========================================
# LOCAL DEVELOPMENT ONLY
# ===========================================
# Set to "true" to bypass E2B and Supabase for local testing
# DO NOT set this in production!
LOCAL_DEV=false

# Local WebSocket URL (only used when LOCAL_DEV=true)
LOCAL_WS_URL=ws://localhost:8080
